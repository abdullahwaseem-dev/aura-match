# Primary LLM provider — get a free key at console.groq.com
GROQ_API_KEY=gsk_...
GROQ_DEEP_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama-3.1-8b-instant

# Optional — only used if you switch back to Claude for a route
ANTHROPIC_API_KEY=sk-ant-...

PORT=8787

# Supabase — backend for cached job listings, AI match scores, and the
# application tracker (Jobs tab). Get these from your project's API settings.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-or-publishable-key
